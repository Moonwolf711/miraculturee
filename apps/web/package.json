{
  "name": "@miraculturee/web",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node server.cjs dist",
    "dev:local": "vite",
    "build": "cd ../.. && pnpm --filter @miraculturee/shared build && cd apps/web && tsc -b && vite build",
    "start": "node server.cjs dist",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@atlaskit/avatar": "^25.10.0",
    "@atlaskit/button": "^23.10.5",
    "@atlaskit/css-reset": "^7.4.0",
    "@atlaskit/form": "^15.5.0",
    "@atlaskit/heading": "^5.3.0",
    "@atlaskit/icon": "^33.1.0",
    "@atlaskit/lozenge": "^13.5.2",
    "@atlaskit/primitives": "^18.1.0",
    "@atlaskit/section-message": "^8.12.8",
    "@atlaskit/spinner": "^19.0.11",
    "@atlaskit/tabs": "^19.0.0",
    "@atlaskit/textfield": "^8.2.3",
    "@atlaskit/toggle": "^15.2.14",
    "@atlaskit/tokens": "^11.4.0",
    "@hcaptcha/react-hcaptcha": "^2.0.2",
    "@miraculturee/shared": "workspace:*",
    "@simplewebauthn/browser": "^11.0.0",
    "@stripe/react-stripe-js": "^3.5.0",
    "@stripe/stripe-js": "^5.5.0",
    "i18next": "^25.8.14",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^2.0.5",
    "react-i18next": "^16.5.6",
    "react-router-dom": "^7.1.0",
    "serve": "^14.2.0",
    "socket.io-client": "^4.8.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.4.20",
    "happy-dom": "^20.6.1",
    "jsdom": "^25.0.1",
    "msw": "^2.7.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
