# Capacitor build artifacts
www/
node_modules/
dist/

# iOS native project (generated by `cap add ios` on a mac)
# Commit the ios/ folder once it exists to enable Codemagic builds.
# Ignore derived / user-specific files:
ios/App/Pods/
ios/DerivedData/
ios/App/App.xcworkspace/xcuserdata/
ios/App/App.xcodeproj/xcuserdata/
ios/App/App.xcodeproj/project.xcworkspace/xcuserdata/
ios/App/public/
*.mobileprovision
*.p12
*.certSigningRequest

# Fastlane
ios/fastlane/report.xml
ios/fastlane/Preview.html
ios/fastlane/screenshots
ios/fastlane/test_output

# Xcode
*.xcuserstate
*.xcuserdatad
*.swp
.DS_Store
