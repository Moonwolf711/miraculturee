# miraculturee Fastfile
#
# Lanes: beta / release — archive + export IPA. No upload.
# Upload handled by codemagic.yaml altool step (Ruby 3.4 JWT EC bug).

default_platform(:ios)

WORKSPACE     = "App.xcworkspace"
SCHEME        = "App"
CONFIG        = "Release"
EXPORT_METHOD = "app-store"
TEAM_ID       = "GMQY9LD9C2"
BUNDLE_ID     = "com.miraculturee.app"

CM_KEYCHAIN = `security list-keychains -d user 2>/dev/null | grep codemagic-cli-tools | head -1 | tr -d '" '`.strip
KEYCHAIN_ARG = CM_KEYCHAIN.empty? ? "" : " OTHER_CODE_SIGN_FLAGS='--keychain #{CM_KEYCHAIN}'"

def find_profile_name(bundle_id)
  dirs = [
    File.expand_path("~/Library/Developer/Xcode/UserData/Provisioning Profiles"),
    File.expand_path("~/Library/MobileDevice/Provisioning Profiles"),
  ]
  dirs.each do |dir|
    next unless Dir.exist?(dir)
    Dir["#{dir}/*.mobileprovision"].each do |path|
      plist_xml = `security cms -D -i "#{path}" 2>/dev/null`
      next if plist_xml.empty?
      name_match = plist_xml.match(/<key>Name<\/key>\s*<string>([^<]+)<\/string>/)
      app_id_match = plist_xml.match(/<key>application-identifier<\/key>\s*<string>[^.]*\.([^<]+)<\/string>/)
      next unless name_match && app_id_match
      if app_id_match[1] == bundle_id || plist_xml.include?(">#{bundle_id}<")
        return name_match[1]
      end
    end
  end
  nil
end

platform :ios do
  desc "Build signed archive + export IPA (no upload)"
  lane :beta do
    profile_name = find_profile_name(BUNDLE_ID)
    export_opts = {
      method: EXPORT_METHOD,
      teamID: TEAM_ID,
      signingStyle: "manual"
    }
    if profile_name
      export_opts[:provisioningProfiles] = { BUNDLE_ID => profile_name }
      UI.success("Provisioning profile: #{profile_name}")
    else
      UI.error("Could not find a matching .mobileprovision for #{BUNDLE_ID}")
    end

    build_app(
      workspace:     WORKSPACE,
      scheme:        SCHEME,
      configuration: CONFIG,
      export_method: EXPORT_METHOD,
      clean:         false,
      xcargs: "DEVELOPMENT_TEAM=#{TEAM_ID} CODE_SIGN_IDENTITY='Apple Distribution' CODE_SIGN_STYLE=Manual#{KEYCHAIN_ARG}",
      export_options: export_opts
    )
  end

  desc "Alias for beta"
  lane :release do
    profile_name = find_profile_name(BUNDLE_ID)
    export_opts = {
      method: EXPORT_METHOD,
      teamID: TEAM_ID,
      signingStyle: "manual"
    }
    export_opts[:provisioningProfiles] = { BUNDLE_ID => profile_name } if profile_name

    build_app(
      workspace:     WORKSPACE,
      scheme:        SCHEME,
      configuration: CONFIG,
      export_method: EXPORT_METHOD,
      clean:         false,
      xcargs: "DEVELOPMENT_TEAM=#{TEAM_ID} CODE_SIGN_IDENTITY='Apple Distribution' CODE_SIGN_STYLE=Manual#{KEYCHAIN_ARG}",
      export_options: export_opts
    )
  end
end
