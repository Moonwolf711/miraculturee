# miraculturee Fastfile
#
# Lanes:
#   beta    — build signed archive + export IPA
#   release — same as beta (App Store submission done manually in ASC)
#
# NOTE: Upload is NOT done here. Fastlane's `app_store_connect_api_key`
# and `upload_to_testflight` actions both fail on Ruby 3.4 + fastlane
# 2.232.2 with `OpenSSL::PKey::EC: invalid curve name` (the ES256 curve
# naming mismatch). Upload is handled by the codemagic.yaml step using
# `xcrun altool` which uses Apple's own binary, bypassing Ruby's broken
# OpenSSL EC handling. See fastlane/fastlane#20553, #22183.
#
# Signing: Codemagic's prior `app-store-connect fetch-signing-files`
# step (using the persistent CERT_KEY_B64 PEM) already installed the
# distribution cert + provisioning profile in the build keychain and
# wrote the signing attrs into project.pbxproj via `xcode-project
# use-profiles`. This Fastfile inherits that state.

default_platform(:ios)

WORKSPACE     = "App.xcworkspace"
SCHEME        = "App"
CONFIG        = "Release"
EXPORT_METHOD = "app-store"
TEAM_ID       = "GMQY9LD9C2"

# Pass CM keychain path to codesign via xcargs. Without `--keychain
# <path>`, archive fails with errSecInternalComponent on Xcode 26+
# because codesign's implicit keychain lookup doesn't find the
# imported Apple Distribution cert. Confirmed via SSH debug 2026-04-14.
CM_KEYCHAIN = `security list-keychains -d user 2>/dev/null | grep codemagic-cli-tools | head -1 | tr -d '" '`.strip
KEYCHAIN_ARG = CM_KEYCHAIN.empty? ? "" : " OTHER_CODE_SIGN_FLAGS='--keychain #{CM_KEYCHAIN}'"

platform :ios do
  desc "Build signed archive + export IPA (no upload)"
  lane :beta do
    build_app(
      workspace:     WORKSPACE,
      scheme:        SCHEME,
      configuration: CONFIG,
      export_method: EXPORT_METHOD,
      clean:         false,
      xcargs: "DEVELOPMENT_TEAM=#{TEAM_ID} CODE_SIGN_IDENTITY='Apple Distribution' CODE_SIGN_STYLE=Manual#{KEYCHAIN_ARG}",
      export_options: {
        method: EXPORT_METHOD,
        teamID: TEAM_ID,
        signingStyle: "manual"
      }
    )
  end

  desc "Alias for beta (upload is done by codemagic.yaml altool step)"
  lane :release do
    build_app(
      workspace:     WORKSPACE,
      scheme:        SCHEME,
      configuration: CONFIG,
      export_method: EXPORT_METHOD,
      clean:         false,
      xcargs: "DEVELOPMENT_TEAM=#{TEAM_ID} CODE_SIGN_IDENTITY='Apple Distribution' CODE_SIGN_STYLE=Manual#{KEYCHAIN_ARG}",
      export_options: {
        method: EXPORT_METHOD,
        teamID: TEAM_ID,
        signingStyle: "manual"
      }
    )
  end
end
