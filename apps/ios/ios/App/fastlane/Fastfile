# miraculturee Fastfile
#
# Lanes: beta / release — archive + export IPA. No upload.
# Upload handled by codemagic.yaml altool step (Ruby 3.4 JWT EC bug).

default_platform(:ios)

WORKSPACE     = "App.xcworkspace"
SCHEME        = "App"
CONFIG        = "Release"
EXPORT_METHOD = "app-store"
TEAM_ID       = "GMQY9LD9C2"
BUNDLE_ID     = "com.miraculturee.app"

CM_KEYCHAIN = `security list-keychains -d user 2>/dev/null | grep codemagic-cli-tools | head -1 | tr -d '" '`.strip
KEYCHAIN_ARG = CM_KEYCHAIN.empty? ? "" : " OTHER_CODE_SIGN_FLAGS='--keychain #{CM_KEYCHAIN}'"

# Read PROVISIONING_PROFILE_SPECIFIER from pbxproj for export_options.
# xcode-project use-profiles writes this into project.pbxproj, but gym's
# export_archive step needs it mirrored in export_options.plist too.
def profile_specifier(project_path = "App.xcodeproj")
  pbx = File.join(project_path, "project.pbxproj")
  return nil unless File.exist?(pbx)
  match = File.read(pbx).match(/PROVISIONING_PROFILE_SPECIFIER\s*=\s*"?([^";\n]+)"?;/)
  match && match[1]
end

PROFILE_NAME = profile_specifier

platform :ios do
  desc "Build signed archive + export IPA (no upload)"
  lane :beta do
    export_opts = {
      method: EXPORT_METHOD,
      teamID: TEAM_ID,
      signingStyle: "manual"
    }
    if PROFILE_NAME
      export_opts[:provisioningProfiles] = { BUNDLE_ID => PROFILE_NAME }
      UI.message("Using provisioning profile: #{PROFILE_NAME}")
    end

    build_app(
      workspace:     WORKSPACE,
      scheme:        SCHEME,
      configuration: CONFIG,
      export_method: EXPORT_METHOD,
      clean:         false,
      xcargs: "DEVELOPMENT_TEAM=#{TEAM_ID} CODE_SIGN_IDENTITY='Apple Distribution' CODE_SIGN_STYLE=Manual#{KEYCHAIN_ARG}",
      export_options: export_opts
    )
  end

  desc "Alias for beta"
  lane :release do
    export_opts = {
      method: EXPORT_METHOD,
      teamID: TEAM_ID,
      signingStyle: "manual"
    }
    if PROFILE_NAME
      export_opts[:provisioningProfiles] = { BUNDLE_ID => PROFILE_NAME }
    end

    build_app(
      workspace:     WORKSPACE,
      scheme:        SCHEME,
      configuration: CONFIG,
      export_method: EXPORT_METHOD,
      clean:         false,
      xcargs: "DEVELOPMENT_TEAM=#{TEAM_ID} CODE_SIGN_IDENTITY='Apple Distribution' CODE_SIGN_STYLE=Manual#{KEYCHAIN_ARG}",
      export_options: export_opts
    )
  end
end
