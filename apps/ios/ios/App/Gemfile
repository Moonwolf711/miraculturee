source "https://rubygems.org"

# Bundler version pin. Codemagic's Ruby 3.4.7 ships with bundler 4.0.1
# which breaks fastlane (requires bundler >= 1.12, < 3.0) AND Capacitor
# cap sync's internal `bundle exec pod install`. Install 2.7.2 explicitly
# via `gem install bundler:2.7.2` in codemagic.yaml, and set
# BUNDLER_VERSION=2.7.2 as a workflow env var so `bundle` picks 2.7.2
# everywhere. Without this, every build fails at 'cap sync ios'.
# See codemagic.yaml 'Install bundler 2.7.2' step.

gem "fastlane", "~> 2.222"

# NOTE: cocoapods is intentionally NOT pinned here — Codemagic provides
# it via `cocoapods: default` in the workflow environment, and adding
# a Gemfile entry for it causes version collisions with Capacitor's
# internal pod install invocation.
