generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  FAN
  LOCAL_FAN
  ARTIST
  AGENT
  ADMIN
  DEVELOPER
}

enum DeveloperInviteStatus {
  PENDING
  ACCEPTED
  CANCELLED
  EXPIRED
}

enum DeveloperPermission {
  FULL
  LIMITED
}

enum EventStatus {
  DRAFT
  AWAITING_ARTIST
  PUBLISHED
  SOLD_OUT
  COMPLETED
  CANCELLED
}

enum RaffleStatus {
  OPEN
  DRAWING
  COMPLETED
  CANCELLED
}

enum PoolTicketStatus {
  AVAILABLE
  ASSIGNED
  REDEEMED
}

enum TransactionType {
  SUPPORT_PURCHASE
  RAFFLE_ENTRY
  TICKET_PURCHASE
  LOCAL_TICKET
  ARTIST_PAYOUT
  REFUND
  CREDIT_CONVERSION
  CREDIT_SPEND
  AGENT_RAFFLE_CREDIT
  AGENT_CREDIT_SPEND
}

enum DirectTicketStatus {
  PENDING
  CONFIRMED
  TRANSFERRED
  REDEEMED
  REFUNDED
}

enum EventType {
  SHOW
  FESTIVAL
  SPORTS
  COMEDY
}

enum ExternalEventStatus {
  DISCOVERED
  IMPORTED
  PUBLISHED
  ARCHIVED
}

enum AcquisitionStatus {
  PENDING
  CARD_CREATED
  PURCHASING
  COMPLETED
  FAILED
}

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  passwordHash        String
  name                String
  role                Role      @default(FAN)
  lat                 Float?
  lng                 Float?
  city                String?
  refreshToken        String?
  emailVerified       Boolean   @default(false)
  emailVerifyToken    String?   @unique
  emailVerifyExpiry   DateTime?
  passwordResetToken  String?   @unique
  passwordResetExpiry DateTime?
  isBanned            Boolean   @default(false)
  bannedAt            DateTime?
  totpSecret          String?
  totpEnabled         Boolean   @default(false)
  totpBackupCodes     String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  artist               Artist?
  connectedAccount     ConnectedAccount?
  supportTickets       SupportTicket[]
  raffleEntries        RaffleEntry[]
  transactions         Transaction[]
  notifications        Notification[]
  directTickets        DirectTicket[]
  suspiciousActivities SuspiciousActivity[]
  passkeys             Passkey[]
  socialLogins         SocialLogin[]
  creditsBalanceCents  Int       @default(0)
  freeRaffleUsed       Boolean   @default(false)
  devInvitesSent       DeveloperInvite[] @relation("DevInvitesSent")
  devInvitesAccepted   DeveloperInvite[] @relation("DevInvitesAccepted")
  promoterAgent        PromoterAgent?
  managedArtists       ArtistManager[]
  localArtistProfile   LocalArtistProfile?
  bookingRequestsSent  BookingRequest[]     @relation("BookingRequestsSent")
}

model Artist {
  id                 String    @id @default(uuid())
  userId             String    @unique
  stageName          String
  genre              String?
  bio                String?
  profileImageUrl     String?
  bannerImageUrl      String?
  city                String?
  state               String?
  websiteUrl          String?
  genres              String[]
  instruments         String[]
  professionalType    String?
  yearsActive         Int?
  hometown            String?
  socialLinks         Json?
  followerCount       Json?
  profileStrength     Int       @default(0)
  stripeAccountId    String?
  isVerified         Boolean   @default(false)
  verifiedAt         DateTime?
  verificationStatus String    @default("UNVERIFIED") // UNVERIFIED | VERIFIED
  isPlaceholder      Boolean   @default(false)
  spotifyArtistId     String?   @unique
  successfulCampaigns Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  events         Event[]
  campaigns      Campaign[]
  socialAccounts ArtistSocialAccount[]
  managers       ArtistManager[]
  managerInvites ManagerInvite[]
}

model ArtistSocialAccount {
  id               String         @id @default(uuid())
  artistId         String
  provider         SocialProvider
  providerUserId   String
  providerUsername String?
  profileUrl       String?
  followerCount    Int?
  accessToken      String? // encrypted
  refreshToken     String? // encrypted
  tokenExpiresAt   DateTime?
  scopes           String?
  rawProfile       Json?
  connectedAt      DateTime       @default(now())
  lastVerifiedAt   DateTime?

  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([artistId, provider])
  @@unique([provider, providerUserId])
  @@index([artistId])
}

enum SocialProvider {
  SPOTIFY
  SOUNDCLOUD
  TIDAL
  INSTAGRAM
  FACEBOOK
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  GOAL_REACHED
  TICKETS_OPEN
  OVERFLOW
  RAFFLE_MODE
  SURPLUS_RESOLVED
  ENDED
}

model Campaign {
  id              String         @id @default(uuid())
  artistId        String
  eventId         String
  headline        String
  message         String
  status          CampaignStatus @default(DRAFT)
  startAt         DateTime?
  endAt           DateTime?
  goalCents       Int            @default(0)
  fundedCents     Int            @default(0)
  goalReached     Boolean        @default(false)
  goalReachedAt   DateTime?
  discountCents   Int            @default(500)
  maxLocalTickets Int            @default(10)
  bonusCents      Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  artist        Artist         @relation(fields: [artistId], references: [id], onDelete: Cascade)
  event         Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  agentCampaign AgentCampaign?

  @@index([artistId])
  @@index([eventId, status])
}

model Event {
  id               String      @id @default(uuid())
  artistId         String
  title            String
  description      String?
  venueName        String
  venueAddress     String
  venueLat         Float
  venueLng         Float
  venueCity        String      @default("")
  date             DateTime
  ticketPriceCents Int
  maxPriceCents    Int?
  totalTickets     Int
  priceSource      String      @default("manual")
  feesIncluded     Boolean     @default(false)
  localRadiusKm    Float       @default(50)
  type             EventType   @default(SHOW)
  status           EventStatus @default(DRAFT)
  flyerImageUrl       String?
  flyerImage2Url      String?
  promoVideoUrl       String?
  eventSocialLinks    Json?
  eventHashtag        String?
  lineupNotes         String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  artist             Artist              @relation(fields: [artistId], references: [id], onDelete: Cascade)
  supportTickets     SupportTicket[]
  poolTickets        PoolTicket[]
  rafflePools        RafflePool[]
  directTickets      DirectTicket[]
  ticketAcquisitions TicketAcquisition[]
  campaigns          Campaign[]
  donorConnections   DonorConnection[]
  shareInvites       ShareInvite[]

  @@index([artistId])
  @@index([status, date])
  @@index([venueCity, date])
  @@index([venueLat, venueLng])
}

model ShareInvite {
  id         String   @id @default(uuid())
  eventId    String
  fanUserId  String?
  shareToken String   @unique @default(uuid())
  platform   String?
  clickCount Int      @default(0)
  createdAt  DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model SupportTicket {
  id               String   @id @default(uuid())
  eventId          String
  userId           String
  ticketCount      Int
  totalAmountCents Int
  message          String?
  stripePaymentId  String?
  confirmed        Boolean  @default(false)
  createdAt        DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  poolTickets PoolTicket[]

  @@index([eventId])
  @@index([userId])
}

model PoolTicket {
  id              String           @id @default(uuid())
  eventId         String
  supportTicketId String
  status          PoolTicketStatus @default(AVAILABLE)
  assignedUserId  String?
  createdAt       DateTime         @default(now())

  event         Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  supportTicket SupportTicket @relation(fields: [supportTicketId], references: [id], onDelete: Cascade)

  @@index([eventId, status])
  @@index([assignedUserId])
}

model RafflePool {
  id                String       @id @default(uuid())
  eventId           String
  tierCents         Int
  status            RaffleStatus @default(OPEN)
  scheduledDrawTime DateTime?
  drawnAt           DateTime?
  seedHash          String?
  revealedSeed      String?
  algorithm         String       @default("SHA-256 + Fisher-Yates + Seedrandom")
  verificationUrl   String?
  createdAt         DateTime     @default(now())

  event   Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  entries RaffleEntry[]

  @@unique([eventId, tierCents])
}

model RaffleEntry {
  id        String   @id @default(uuid())
  poolId    String
  userId    String
  won       Boolean  @default(false)
  ticketId  String?
  entryDate DateTime @default(now()) @db.Date
  createdAt DateTime @default(now())

  pool RafflePool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([poolId, userId, entryDate])
  @@index([poolId])
  @@index([userId])
}

model Transaction {
  id              String          @id @default(uuid())
  userId          String
  type            TransactionType
  amountCents     Int
  currency        String          @default("usd")
  stripePaymentId String?
  posReference    String?
  status          String          @default("pending")
  metadata        Json?
  createdAt       DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  read      Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model DirectTicket {
  id                String             @id @default(uuid())
  eventId           String
  ownerId           String
  status            DirectTicketStatus @default(PENDING)
  priceCents        Int
  feeCents          Int
  stripePaymentId   String?
  ipAddress         String?
  deviceFingerprint String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  owner User  @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([eventId, ownerId])
  @@index([eventId])
  @@index([ownerId])
}

model ExternalEvent {
  id         String @id @default(uuid())
  externalId String
  source     String
  sourceUrl  String

  // Event details
  title       String
  description String?
  artistName  String
  artistId    String?

  // Venue details
  venueName    String
  venueAddress String
  venueCity    String
  venueState   String?
  venueCountry String
  venueLat     Float?
  venueLng     Float?
  venueId      String?

  // Timing
  eventDate   DateTime
  onSaleDate  DateTime?
  offSaleDate DateTime?

  // Pricing
  minPriceCents Int?
  maxPriceCents Int?
  currency      String @default("USD")

  // Classification
  genre    String?
  category String?

  // Status
  status          ExternalEventStatus @default(DISCOVERED)
  importedEventId String?

  // Metadata
  rawData      Json
  lastSyncedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([externalId, source])
  @@index([eventDate])
  @@index([venueCity, eventDate])
  @@index([status])
  @@index([source])
}

model EventSyncLog {
  id            String   @id @default(uuid())
  source        String
  status        String
  eventsFound   Int
  eventsNew     Int
  eventsUpdated Int
  errorMessage  String?
  startedAt     DateTime
  completedAt   DateTime

  @@index([source, startedAt])
}

model TicketAcquisition {
  id               String            @id @default(uuid())
  eventId          String
  ticketCount      Int
  totalAmountCents Int
  status           AcquisitionStatus @default(PENDING)
  stripeCardId     String?
  cardLast4        String?
  purchaseUrl      String?
  confirmationRef  String?
  errorMessage     String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([status])
}

// ─── Stripe Connect ───
// Stores the mapping between a MiraCulture user and their Stripe Connected Account.
// The stripeAccountId is the V2 account ID (shape: acct_...) returned by
// stripeClient.v2.core.accounts.create(). We track onboarding status here so we
// know when the account is ready to accept payments.
model ConnectedAccount {
  id                 String   @id @default(uuid())
  userId             String   @unique
  stripeAccountId    String   @unique // The Stripe account ID (acct_...)
  displayName        String // Business/artist display name
  onboardingComplete Boolean  @default(false)
  paymentsEnabled    Boolean  @default(false) // card_payments capability is active
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions ConnectSubscription[]

  @@index([stripeAccountId])
}

// Tracks subscription status for connected accounts subscribing to the platform.
// Updated via Stripe webhooks (customer.subscription.updated/deleted).
// The stripeSubscriptionId is the sub_... ID from Stripe.
model ConnectSubscription {
  id                   String    @id @default(uuid())
  connectedAccountId   String
  stripeSubscriptionId String    @unique // sub_...
  status               String    @default("incomplete") // active, past_due, canceled, etc.
  priceId              String? // The Stripe price ID
  currentPeriodEnd     DateTime? // When the current billing period ends
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  connectedAccount ConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)

  @@index([connectedAccountId])
  @@index([status])
}

model SuspiciousActivity {
  id        String   @id @default(uuid())
  userId    String?
  type      String
  ip        String
  riskScore Int?
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([ip])
  @@index([type])
  @@index([createdAt])
}

model DonorConnection {
  id              String    @id @default(uuid())
  eventId         String
  donorUserId     String
  receiverUserId  String?
  donorSocials    Json?
  receiverChoice  String?
  receiverSocials Json?
  thankYouMessage String?
  matched         Boolean   @default(false)
  matchedAt       DateTime?
  createdAt       DateTime  @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, matched])
  @@index([donorUserId])
  @@index([receiverUserId])
}

model Passkey {
  id           String   @id @default(uuid())
  userId       String
  credentialId String   @unique
  publicKey    Bytes
  counter      BigInt   @default(0)
  friendlyName String   @default("My Passkey")
  transports   String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SocialLogin {
  id             String   @id @default(uuid())
  userId         String
  provider       String
  providerUserId String
  email          String?
  name           String?
  avatarUrl      String?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
}

model DeveloperInvite {
  id           String                @id @default(uuid())
  email        String
  token        String                @unique @default(uuid())
  status       DeveloperInviteStatus @default(PENDING)
  permission   DeveloperPermission   @default(LIMITED)
  invitedById  String
  acceptedById String?
  acceptedAt   DateTime?
  expiresAt    DateTime
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  invitedBy  User  @relation("DevInvitesSent", fields: [invitedById], references: [id], onDelete: Cascade)
  acceptedBy User? @relation("DevInvitesAccepted", fields: [acceptedById], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([status])
}

// ─── Promoter Agent Marketplace ───

enum AgentVerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model PromoterAgent {
  id                 String                  @id @default(uuid())
  userId             String                  @unique
  displayName        String
  bio                String?
  headline           String?                 // short tagline (e.g. "Club Promoter in NYC")
  state              String                  // US state abbreviation (e.g. "NY", "CA")
  city               String
  age                Int?
  profileImageUrl    String?
  bannerImageUrl     String?
  yearsExperience    Int?                    // years in the music/events industry
  promoterType       String?                 // Concert, Club, Festival, Venue, Street Team, Independent
  genres             String[]                // music genres they specialize in
  skills             String[]                // specific skills (Social Media, Flyering, Venue Booking, etc.)
  venueExperience    String?                 // venues they've worked with
  promotionHistory   String?                 // past shows/events promoted
  socialLinks        Json?                   // { instagram, twitter, tiktok, website }
  verificationStatus AgentVerificationStatus @default(PENDING)
  verificationNote   String?                 // admin note on approval/rejection
  verifiedAt         DateTime?
  revenueSharePct    Int                     @default(50)  // % of campaign proceeds
  totalCampaigns     Int                     @default(0)
  totalEarnedCents   Int                     @default(0)
  rating             Float?                  // average rating from artists
  ratingCount        Int                     @default(0)
  profileStrength    Int                     @default(0)   // 0-100 completion percentage
  // Subscription ($19.99/mo)
  stripeCustomerId     String?               @unique
  stripeSubscriptionId String?               @unique
  subscriptionStatus   String                @default("none") // none, active, past_due, canceled, trialing
  subscriptionEndAt    DateTime?             // current period end
  // Raffle credits ($5/mo, use-it-or-lose-it)
  raffleCreditCents    Int                   @default(0)
  creditResetAt        DateTime?             // when credits expire (end of billing period)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns AgentCampaign[]

  @@index([state])
  @@index([verificationStatus])
  @@index([state, verificationStatus])
}

model AgentCampaign {
  id              String   @id @default(uuid())
  agentId         String
  campaignId      String   @unique  // one agent per campaign
  status          String   @default("ACTIVE")  // ACTIVE, COMPLETED, CANCELLED
  revenueSharePct Int      @default(50)
  earnedCents     Int      @default(0)
  paidOut         Boolean  @default(false)
  artistRating    Int?     // 1-5 star rating from artist
  artistReview    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  agent    PromoterAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  campaign Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([campaignId])
}

// ─── Artist Manager System ───

enum ManagerPermission {
  READ
  READ_WRITE
}

model ManagerInvite {
  id         String             @id @default(uuid())
  artistId   String
  token      String             @unique @default(uuid())
  permission ManagerPermission  @default(READ_WRITE)
  email      String?
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime           @default(now())

  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@index([artistId])
  @@index([token])
}

model ArtistManager {
  id              String             @id @default(uuid())
  artistId        String
  userId          String
  permission      ManagerPermission  @default(READ_WRITE)
  displayName     String
  bio             String?
  profileImageUrl String?
  addedAt         DateTime           @default(now())

  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([artistId, userId])
  @@index([artistId])
  @@index([userId])
}

// ─── Ticketing Platform Integration Management ───

enum PlatformIntegrationStatus {
  NOT_STARTED
  CONTACTED
  PENDING_APPROVAL
  API_KEY_RECEIVED
  ACTIVE
  REJECTED
  SUSPENDED
}

model TicketingPlatform {
  id              String                    @id @default(uuid())
  name            String                    @unique
  displayName     String
  status          PlatformIntegrationStatus @default(NOT_STARTED)
  apiKey          String?
  apiSecret       String?
  devPortalUrl    String?
  contactEmail    String?
  contactedAt     DateTime?
  approvedAt      DateTime?
  notes           String?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  contactLogs PlatformContactLog[]
}

model PlatformContactLog {
  id          String   @id @default(uuid())
  platformId  String
  messageType String
  subject     String
  body        String
  sentById    String?
  sentAt      DateTime @default(now())

  platform TicketingPlatform @relation(fields: [platformId], references: [id], onDelete: Cascade)

  @@index([platformId])
}

model NewsletterSubscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([active])
}

// ─── Local Artist EPK (Electronic Press Kit) ───

model LocalArtistProfile {
  id                  String    @id @default(uuid())
  userId              String    @unique
  stageName           String
  city                String
  state               String    // US state abbreviation (e.g. "NY", "CA")
  bio                 String?
  profileImageUrl     String?
  bannerImageUrl      String?
  genres              String[]
  instruments         String[]
  professionalType    String?   // DJ/Producer, Vocalist, Band, Instrumentalist, etc.
  yearsActive         Int?
  bookingEmail        String?
  bookingRate         String?   // e.g. "$200-500", flexible text
  availableForBooking Boolean   @default(true)
  epkUrl              String?   // external EPK link
  socialLinks         Json?     // { instagram, twitter, tiktok, spotify, soundcloud, youtube, website }
  followerCount       Json?     // { instagram: Int, twitter: Int, tiktok: Int, spotify: Int, soundcloud: Int }
  verificationStatus  String    @default("UNVERIFIED") // UNVERIFIED, VERIFIED
  profileStrength     Int       @default(0)  // 0-100
  totalShows          Int       @default(0)
  totalTicketsSold    Int       @default(0)
  avgTicketsPerShow   Float     @default(0)
  lastBookedAt        DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  releases        LocalArtistRelease[]
  pastShows       LocalArtistShow[]
  bookingRequests BookingRequest[]     @relation("BookingRequestsReceived")

  @@index([city, state])
  @@index([state])
  @@index([availableForBooking])
}

model LocalArtistRelease {
  id              String    @id @default(uuid())
  artistProfileId String
  title           String
  type            String    // Single, EP, Album, Mixtape, Remix
  platform        String?   // Spotify, SoundCloud, Apple Music, YouTube, etc.
  url             String?
  releaseDate     DateTime?
  streamCount     Int?      // self-reported
  coverImageUrl   String?
  createdAt       DateTime  @default(now())

  artistProfile LocalArtistProfile @relation(fields: [artistProfileId], references: [id], onDelete: Cascade)

  @@index([artistProfileId])
}

model LocalArtistShow {
  id              String    @id @default(uuid())
  artistProfileId String
  venueName       String
  venueCity       String
  eventTitle      String?
  date            DateTime
  role            String    // Headliner, Direct Support, Opener, Guest, Resident
  ticketsSold     Int?
  totalAttendance Int?
  promoterName    String?
  notes           String?
  createdAt       DateTime  @default(now())

  artistProfile LocalArtistProfile @relation(fields: [artistProfileId], references: [id], onDelete: Cascade)

  @@index([artistProfileId, date])
}

model BookingRequest {
  id            String    @id @default(uuid())
  localArtistId String
  requesterId   String
  eventTitle    String
  venueName     String
  eventDate     DateTime
  offeredRole   String    // Opener, Direct Support, Co-Headliner
  compensation  String?   // text description
  message       String?
  status        String    @default("PENDING") // PENDING, ACCEPTED, DECLINED, CANCELLED
  respondedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  localArtist LocalArtistProfile @relation("BookingRequestsReceived", fields: [localArtistId], references: [id], onDelete: Cascade)
  requester   User               @relation("BookingRequestsSent", fields: [requesterId], references: [id], onDelete: Cascade)

  @@index([localArtistId, status])
  @@index([requesterId])
}

model EmailSubscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  source    String?
  optedInAt DateTime @default(now())
}
